PORT=5000

# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/flaghouse

# MongoDB Atlas (cloud) — replace user, password, and cluster host:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/flaghouse?retryWrites=true&w=majority

MONGODB_URI=mongodb://127.0.0.1:27017/flaghouse
# Comma-separated if you use multiple frontend ports
CLIENT_URL=http://localhost:5174,http://localhost:5175

JWT_SECRET=your_long_random_secret_here
JWT_EXPIRES_IN=7d

# Comma-separated emails that receive admin role (new signups + promote-admin script)
ADMIN_EMAIL=your-email@example.com

# Inbox for contact form submissions (defaults to first ADMIN_EMAIL if unset)
CONTACT_EMAIL=your-email@example.com

RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# From Razorpay Dashboard → Webhooks (after creating webhook endpoint)
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx

# Password reset emails (Resend — https://resend.com)
# Without RESEND_API_KEY, reset links are logged to the server console only.
RESEND_API_KEY=re_xxxxxxxx
# Use onboarding@resend.dev for testing, or your verified domain in production
EMAIL_FROM=FlagHouse <onboarding@resend.dev>
